---
import Layout from '../layouts/Layout.astro';

const title = "Page Not Found | LinkHeadGen";
const description = "The page you are looking for does not exist or has been moved. Return to LinkHeadGen.com to generate your LinkedIn headlines.";
---

<Layout title={title} description={description}>
  <section class="section" style="min-height: 75vh; display: flex; align-items: center; justify-content: center; padding: 3rem 0;">
    <div class="container">
      <div class="card text-center" style="max-width: 580px; margin: 0 auto; padding: 3rem 2rem;">
        
        <!-- Premium SVG 404 Illustration -->
        <div style="margin-bottom: 2rem; display: flex; justify-content: center; color: var(--primary);">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            <line x1="8" y1="11" x2="14" y2="11"></line>
            <line x1="11" y1="8" x2="11" y2="14"></line>
            <circle cx="11" cy="11" r="2" fill="currentColor" style="opacity: 0.15;"></circle>
          </svg>
        </div>

        <h1 style="font-size: 2.25rem; margin-bottom: 1rem; font-family: var(--font-display);">404 – Page Not Found</h1>
        <p style="font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 2.5rem; line-height: 1.6;">
          Oops! The page you are looking for doesn't exist, has been moved, or is temporarily unavailable. Let's get you back on track.
        </p>

        <!-- Main Navigation CTAs -->
        <div class="form-actions" style="margin-bottom: 2.5rem;">
          <a href="/" class="btn btn-primary w-full" id="404-home-btn">Go to Homepage</a>
          <a href="/#generator" class="btn btn-secondary w-full" id="404-gen-btn">Generate Headlines</a>
        </div>

        <hr style="border: none; border-top: 1px solid var(--border-color); margin-bottom: 1.5rem;" />

        <!-- Popular Sections Shortcuts -->
        <div>
          <p style="font-size: 0.875rem; font-weight: 600; color: var(--text-muted); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">
            Or explore popular sections:
          </p>
          <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem 1.25rem; font-size: 0.95rem;">
            <a href="/#generator" style="font-weight: 600; color: var(--primary);">Generator Tool</a>
            <a href="/#formulas" style="font-weight: 600; color: var(--primary);">Headline Formulas</a>
            <a href="/#tips" style="font-weight: 600; color: var(--primary);">Optimization Tips</a>
            <a href="/#faq" style="font-weight: 600; color: var(--primary);">FAQ Section</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
