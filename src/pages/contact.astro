---
import Layout from '../layouts/Layout.astro';

const title = "Contact Us | LinkHeadGen.com";
const description = "Have questions or feedback? Get in touch with the LinkHeadGen.com support team. We'd love to hear from you.";
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container">
      <div class="seo-content-container">
        <div class="card">
          <h1 class="mb-4 text-center">Contact Us</h1>
          <p class="text-center" style="font-size: 1.15rem; color: var(--text-muted); margin-bottom: 2.5rem;">
            Have suggestions, feature requests, or questions? Send us a message!
          </p>

          <hr style="border: none; border-top: 1px solid var(--border-color); margin-bottom: 2rem;" />

          <div class="grid-2" style="grid-template-columns: 1fr; gap: 2rem;">
            <!-- Simple Form -->
            <form onsubmit="event.preventDefault(); alert('Thank you for your message! This is a demo form, but we will connect soon.');" style="display: flex; flex-direction: column; gap: 1.25rem;">
              <div class="form-group">
                <label for="contact-name">Your Name</label>
                <input type="text" id="contact-name" class="input-text" placeholder="Alex Morgan" required />
              </div>
              
              <div class="form-group">
                <label for="contact-email">Email Address</label>
                <input type="email" id="contact-email" class="input-text" placeholder="alex@example.com" required />
              </div>

              <div class="form-group">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" class="input-text" rows="5" placeholder="Write your message here..." style="resize: vertical; font-family: inherit; font-size: inherit;" required></textarea>
              </div>

              <button type="submit" class="btn btn-primary w-full">Send Message</button>
            </form>

            <div style="background-color: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 1.5rem; text-align: center; display: flex; flex-direction: column; justify-content: center; gap: 1rem;">
              <h3>Direct Email Support</h3>
              <p>Skip the form and email us directly. We typically reply within 24–48 hours.</p>
              <a href="mailto:support@linkheadgen.com" style="font-weight: 700; font-size: 1.2rem; color: var(--primary);">support@linkheadgen.com</a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>
