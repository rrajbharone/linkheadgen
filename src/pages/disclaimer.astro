---
import Layout from '../layouts/Layout.astro';

const title = "Disclaimer | LinkHeadGen.com";
const description = "Read the legal disclaimer for LinkHeadGen.com. We are an independent tool and not affiliated with LinkedIn Corp.";
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container">
      <div class="seo-content-container">
        <div class="card">
          <h1 class="mb-4 text-center">Legal Disclaimer</h1>
          <p class="text-center" style="font-size: 1.1rem; color: var(--text-muted); margin-bottom: 2rem;">
            Last Updated: June 24, 2026
          </p>

          <hr style="border: none; border-top: 1px solid var(--border-color); margin-bottom: 2rem;" />

          <h3>1. No Affiliation with LinkedIn</h3>
          <p>
            <strong>LinkHeadGen.com is an independent, third-party utility.</strong> We are not affiliated, associated, authorized, endorsed by, or in any way officially connected with LinkedIn Corporation, Microsoft Corporation, or any of their subsidiaries or affiliates.
          </p>
          <p>
            The official LinkedIn website can be found at <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer">https://www.linkedin.com</a>. The name "LinkedIn" as well as related names, marks, emblems, and images are registered trademarks of their respective owners.
          </p>

          <h3>2. Educational & Informational Purposes Only</h3>
          <p>
            All headline layouts, copywriting formulas, and structural advices displayed on this website are provided for educational and career improvement purposes only. While our templates utilize standard keyword-rich and recruiter-friendly copywriting formulas, we do not promise or guarantee that using these headlines will:
          </p>
          <ul>
            <li>Increase your profile views or connection statistics.</li>
            <li>Result in callbacks, job offers, or client sales leads.</li>
            <li>Influence your ranking in LinkedIn Recruiter dashboard searches.</li>
          </ul>

          <h3>3. Accuracy of Generated Content</h3>
          <p>
            Our tool uses pattern-based logic to fill fields with your inputs. It is your responsibility to review the output configurations for typographical errors, factual accuracy, and alignment with your true professional background before pasting them onto your public social media profile.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
