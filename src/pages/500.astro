---
import Layout from '../layouts/Layout.astro';

const title = "Server Error | LinkHeadGen";
const description = "An unexpected error occurred on the server. Try refreshing the page or return to LinkHeadGen.com.";
---

<Layout title={title} description={description}>
  <section class="section" style="min-height: 75vh; display: flex; align-items: center; justify-content: center; padding: 3rem 0;">
    <div class="container">
      <div class="card text-center" style="max-width: 580px; margin: 0 auto; padding: 3rem 2rem;">
        
        <!-- Premium SVG 500 Illustration -->
        <div style="margin-bottom: 2rem; display: flex; justify-content: center; color: var(--error);">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
            <line x1="6" y1="6" x2="6.01" y2="6"></line>
            <line x1="6" y1="18" x2="6.01" y2="18"></line>
            <path d="M18 6l-4 4m0-4l4 4" style="stroke: var(--error); stroke-width: 2px;"></path>
            <circle cx="12" cy="18" r="1" fill="currentColor"></circle>
          </svg>
        </div>

        <h1 style="font-size: 2.25rem; margin-bottom: 1rem; font-family: var(--font-display);">500 – Something Went Wrong</h1>
        <p style="font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 2.5rem; line-height: 1.6;">
          An unexpected error occurred on our server. Don't worry, your local data (favorites and history) is completely safe. Let's try to reload the session.
        </p>

        <!-- CTAs: Reload and Return Home -->
        <div class="form-actions">
          <button onclick="window.location.reload();" class="btn btn-primary w-full" id="500-retry-btn">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right: 2px; vertical-align: middle;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89H18v3z"></path>
            </svg>
            Try Again
          </button>
          <a href="/" class="btn btn-secondary w-full" id="500-home-btn">Go to Homepage</a>
        </div>

      </div>
    </div>
  </section>
</Layout>
